{
  "schema_version": 1,
  "description": "Phase 5I sandbox configuration. Conservative defaults — no installs, no external network, no shell=True. Allowlist-based command runner. Real project files are never written by simulation. Restore is dry-run by default.",
  "snapshot_root_relative": "backups",
  "sandbox_root_relative": "logic_updates",
  "manifest_path_relative": "memory/luna_snapshot_manifest.jsonl",
  "report_path_relative_json": "memory/luna_sandbox_report.json",
  "report_path_relative_md": "memory/luna_sandbox_report.md",
  "max_snapshot_file_bytes": 5242880,
  "default_command_timeout_seconds": 30,
  "max_command_timeout_seconds": 120,
  "default_command_allowlist": [
    "python -m py_compile",
    "python -m unittest",
    "python -c",
    "git status --short",
    "git diff --stat",
    "powershell -NoProfile -Command Test-Path"
  ],
  "denied_command_patterns": [
    "(?i)\\bpip(?:3)?\\s+install\\b",
    "(?i)\\bpython\\s+-m\\s+pip\\s+install\\b",
    "(?i)\\bnpm\\s+install\\b",
    "(?i)\\byarn\\s+add\\b",
    "(?i)\\bwinget\\s+install\\b",
    "(?i)\\bchoco\\s+install\\b",
    "(?i)\\bapt(?:-get)?\\s+install\\b",
    "(?i)\\bbrew\\s+install\\b",
    "(?i)\\bpacman\\s+-S\\b",
    "(?i)\\b(?:msiexec|setup\\.exe)\\b",
    "(?i)Install-Module\\b",
    "(?i)Add-AppxPackage\\b",
    "(?i)\\bgit\\s+reset\\b",
    "(?i)\\bgit\\s+clean\\b",
    "(?i)\\bgit\\s+push\\s+--force\\b",
    "(?i)\\brm\\s+-rf\\b",
    "(?i)\\bdel\\s+/[fqs]\\b",
    "(?i)\\bRemove-Item\\b",
    "(?i)\\brmdir\\b",
    "(?i)\\btaskkill\\b",
    "(?i)\\bcurl\\s+(?!.*(?:127\\.0\\.0\\.1|localhost))",
    "(?i)\\bwget\\s+(?!.*(?:127\\.0\\.0\\.1|localhost))",
    "(?i)\\bInvoke-WebRequest\\b",
    "(?i)\\bInvoke-RestMethod\\b"
  ],
  "supported_patch_types": ["replace_text", "append_text"],
  "unsupported_patch_types": ["unified_diff"],
  "unsupported_patch_note": "Unified-diff records are validated for shape but not auto-applied. Phase 5I refuses to silently corrupt files; flag as needs_external_patcher.",
  "restore_default_dry_run": true,
  "restore_requires_explicit_allow": true
}
