{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Luna Dynamic Task Graph",
  "description": "Phase 5H task graph schema. Read-mostly. Foundation module only — does not auto-execute tasks, edit files, call Aider, run installs, or modify queues.",
  "type": "object",
  "required": [
    "schema_version",
    "graph_id",
    "created_at",
    "updated_at",
    "source_goal",
    "normalized_goal",
    "tasks",
    "overall_risk_level",
    "overall_approval_tier_required",
    "intent_drift"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "graph_id": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "source_goal": { "type": "string" },
    "normalized_goal": { "type": "string" },
    "project_dir": { "type": "string" },
    "overall_risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "overall_approval_tier_required": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "title",
          "description",
          "state",
          "dependencies",
          "target_files",
          "risk_level",
          "approval_tier_required",
          "exit_criteria",
          "verification_commands",
          "rollback_plan",
          "expected_artifacts",
          "blockers",
          "created_at",
          "updated_at",
          "source_goal"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["proposed", "ready", "blocked", "running", "done", "failed", "skipped"]
          },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "target_files": { "type": "array", "items": { "type": "string" } },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "approval_tier_required": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "exit_criteria": { "type": "array" },
          "verification_commands": { "type": "array", "items": { "type": "string" } },
          "rollback_plan": { "type": "string" },
          "expected_artifacts": { "type": "array", "items": { "type": "string" } },
          "blockers": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "source_goal": { "type": "string" },
          "task_type": { "type": "string" },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "intent_drift": {
      "type": "object",
      "required": ["drift_score", "status", "evidence", "recommended_action"],
      "properties": {
        "drift_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "status": {
          "type": "string",
          "enum": ["aligned", "watch", "drifted"]
        },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "recommended_action": {
          "type": "string",
          "enum": ["continue", "pause_for_approval"]
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
