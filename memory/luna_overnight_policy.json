{
  "schema_version": 1,
  "description": "Phase 5K overnight policy. Conservative — read-only/generated-artifacts only. No code edits, no Aider, no installs, no process kills, no external network.",
  "default_mode": "read_only",
  "max_cycles": 12,
  "sleep_seconds": 300,
  "max_runtime_minutes": 360,
  "allow_code_edits": false,
  "allow_aider": false,
  "allow_installs": false,
  "allow_process_kill": false,
  "allow_external_network": false,
  "allowed_task_classes": [
    "read_only_health_check",
    "file_map_refresh",
    "memory_index_refresh",
    "scorecard_refresh",
    "resource_snapshot",
    "playbook_match_recent_failures",
    "task_graph_plan_only",
    "sandbox_self_test",
    "upgrade_gate_evaluate_only",
    "daily_brief_report",
    "recommended_next_actions_report"
  ],
  "forbidden_task_classes": [
    "code_edit",
    "aider_patch",
    "package_install",
    "multi_file_refactor",
    "worker_edit",
    "guardian_edit",
    "bridge_edit",
    "launcher_edit",
    "memory_delete",
    "log_delete",
    "queue_delete",
    "external_network",
    "git_reset",
    "git_clean",
    "git_push",
    "process_kill",
    "continues_update_start"
  ],
  "stop_files": [
    "LUNA_STOP_NOW.flag",
    "memory/limited_autonomy.stop",
    "memory/continues_update.stop"
  ],
  "requires_clean_verifier": true,
  "requires_git_clean_for_generated_only": true,
  "max_per_cycle_runtime_seconds": 600,
  "lock_stale_seconds": 3600
}
