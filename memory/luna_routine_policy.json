{
  "schema_version": 1,
  "description": "Phase 5K2 + 5Q limited routine autonomy policy. Replaces 'overnight' framing with 'routine' — Luna runs the same safety rules day or night. Canonical source of truth for limited routine autonomy. memory/luna_overnight_policy.json is kept as a backwards-compatible legacy alias.",
  "default_mode": "read_only",
  "max_cycles": 12,
  "sleep_seconds": 300,
  "max_runtime_minutes": 360,
  "allow_code_edits": false,
  "allow_aider": false,
  "allow_installs": false,
  "allow_process_kill": false,
  "allow_external_network": false,
  "approval_routing_enabled": true,
  "approval_routing_phase": "5Q",
  "allow_execution_from_receipt": false,
  "route_forbidden_code_tasks_to_approval": true,
  "approval_router_module": "luna_modules.luna_approval_router",
  "approval_request_outputs": [
    "memory/luna_routine_approval_requests.jsonl",
    "memory/luna_routine_approval_report.json",
    "memory/luna_routine_approval_report.md"
  ],
  "allowed_task_classes": [
    "read_only_health_check",
    "file_map_refresh",
    "memory_index_refresh",
    "scorecard_refresh",
    "resource_snapshot",
    "playbook_match_recent_failures",
    "task_graph_plan_only",
    "sandbox_self_test",
    "upgrade_gate_evaluate_only",
    "daily_brief_report",
    "recommended_next_actions_report"
  ],
  "forbidden_task_classes": [
    "code_edit",
    "aider_patch",
    "package_install",
    "multi_file_refactor",
    "worker_edit",
    "guardian_edit",
    "bridge_edit",
    "launcher_edit",
    "memory_delete",
    "log_delete",
    "queue_delete",
    "external_network",
    "git_reset",
    "git_clean",
    "git_push",
    "process_kill",
    "continues_update_start"
  ],
  "stop_files": [
    "LUNA_STOP_NOW.flag",
    "memory/limited_autonomy.stop",
    "memory/routine_autonomy.stop",
    "memory/continues_update.stop"
  ],
  "requires_clean_verifier": true,
  "requires_git_clean_for_generated_only": true,
  "max_per_cycle_runtime_seconds": 600,
  "lock_stale_seconds": 3600,
  "naming": {
    "operator_facing_name": "limited routine autonomy",
    "legacy_alias": "overnight autonomy",
    "policy_file": "memory/luna_routine_policy.json",
    "legacy_policy_file": "memory/luna_overnight_policy.json"
  }
}
