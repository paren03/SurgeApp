{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Luna Schema Review Helper Output Schema",
  "description": "Phase 6A: inventory + dangerous-flag review of every tracked Luna schema/policy/checklist/roadmap file. advisory_only=true; live_enforcement_enabled stays false.",
  "definitions": {
    "inventory_record": {
      "type": "object",
      "required": ["path", "sha256", "kind", "risk_level", "parse_ok"],
      "properties": {
        "path": {"type": "string"},
        "absolute_path": {"type": "string"},
        "sha256": {"type": "string"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "modified_at": {"type": "string"},
        "schema_version": {"type": ["integer", "null"]},
        "kind": {
          "type": "string",
          "enum": ["schema", "policy", "checklist", "roadmap", "config", "unknown"]
        },
        "purpose_guess": {"type": "string"},
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical", "unknown"]
        },
        "dangerous_flags": {"type": "array", "items": {"type": "string"}},
        "safe_flags": {"type": "array", "items": {"type": "string"}},
        "parse_ok": {"type": "boolean"},
        "parse_error": {"type": "string"},
        "manual_review_notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "schema_review_report": {
      "type": "object",
      "required": [
        "schema_version", "review_id", "generated_at", "project_dir",
        "advisory_only", "live_enforcement_enabled", "safe_to_execute_now",
        "safe_to_apply_real_project", "files_reviewed", "verdict",
        "inventory", "serge_summary"
      ],
      "properties": {
        "schema_version": {"type": "integer", "const": 1},
        "review_id": {"type": "string"},
        "generated_at": {"type": "string"},
        "project_dir": {"type": "string"},
        "advisory_only": {"type": "boolean", "const": true},
        "live_enforcement_enabled": {"type": "boolean", "const": false},
        "safe_to_execute_now": {"type": "boolean", "const": false},
        "safe_to_apply_real_project": {"type": "boolean", "const": false},
        "files_reviewed": {"type": "integer", "minimum": 0},
        "dangerous_flags_count": {"type": "integer", "minimum": 0},
        "missing_expected_files_count": {"type": "integer", "minimum": 0},
        "parse_error_count": {"type": "integer", "minimum": 0},
        "verdict": {
          "type": "string",
          "enum": [
            "PASS_READY_FOR_SERGE_REVIEW",
            "FAIL_DANGEROUS_POLICY",
            "INCOMPLETE_MISSING_FILES"
          ]
        },
        "inventory": {
          "type": "array",
          "items": {"$ref": "#/definitions/inventory_record"}
        },
        "dangerous_findings": {"type": "array"},
        "missing_expected_files": {"type": "array", "items": {"type": "string"}},
        "serge_summary": {"type": "string"},
        "recommended_next_action": {"type": "string"},
        "phase_archive_copy": {"type": "string"},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
