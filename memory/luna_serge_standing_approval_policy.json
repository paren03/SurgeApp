{
  "schema_version": 1,
  "serge_is_not_expected_to_review_code_line_by_line": true,
  "standing_yes_when_green": true,
  "standing_no_when_red_or_unclear": true,
  "eligible_delegated_tiers_future": [0, 1, 2, 3],
  "high_risk_core_requires_strict_review": true,
  "non_delegable_always_waits_for_serge": true,
  "plain_english_decision_cards_required": true,
  "default_approve_requires": [
    "goal_aligned_with_super_ai_north_star",
    "action_is_delegable",
    "no_non_delegable_flags",
    "no_secret_exposure",
    "sandbox_passed_when_required",
    "verifier_passed",
    "rollback_exists",
    "receipt_or_quorum_valid_when_required",
    "resource_status_not_blocked",
    "target_files_match_receipt",
    "diff_hash_bound_when_required",
    "safe_to_execute_now_future_true_only_after_live_wiring"
  ],
  "default_wait_or_deny_if": [
    "reviewers_disagree",
    "evidence_missing",
    "verifier_failed",
    "sandbox_failed",
    "rollback_missing",
    "receipt_missing_or_stale",
    "target_mismatch",
    "secret_detected",
    "non_delegable_action",
    "destructive_action",
    "package_install_without_policy",
    "architecture_replacement",
    "policy_weakening",
    "memory_or_log_deletion",
    "unclear_goal_alignment"
  ],
  "non_delegable_actions": [
    "delete_memory",
    "delete_logs",
    "delete_queues",
    "delete_backups",
    "delete_uploads",
    "delete_tasks",
    "delete_solutions",
    "wipe_computer",
    "format_drive",
    "change_identity",
    "change_personality",
    "change_goals",
    "expose_secret",
    "package_install_without_policy",
    "external_network_without_policy",
    "git_push_force",
    "git_reset_hard",
    "git_clean_fd",
    "disable_verifier",
    "weaken_quorum_policy",
    "replace_architecture",
    "edit_policy_to_approve_itself"
  ]
}
