# Phase 4D: runtime telemetry — append-only logs that grow every CU cycle.
# Files stay on disk; they are simply not tracked so future appends do not
# dirty the working tree. Use `git rm --cached` once to untrack the existing
# tracked copy without deleting it from disk.
memory/nightly_updates.jsonl
memory/nightly_updates.md

# Phase 5B: regenerable file self-map outputs. luna_module_roles.json and
# luna_risk_zones.json are curated config and stay tracked. luna_file_map.json
# and luna_function_index.json are larger runtime regenerable artifacts —
# rebuild via refresh_curated_self_map() instead of committing.
memory/luna_file_map.json
memory/luna_function_index.json

# Phase 5C: append-only runtime change ledger. Grows every time Luna records
# a change. The schema reference (memory/luna_change_ledger.schema.json) is
# the tracked source of truth; the runtime jsonl stays untracked.
memory/luna_change_ledger.jsonl

# Phase 5D: regenerable memory-index outputs. The tracked sources of truth
# are memory/luna_memory_index.schema.json and memory/luna_memory_sources.json;
# everything below is rebuilt on demand by luna_memory_index.build_memory_index().
memory/luna_memory_index.json
memory/luna_memory_summaries.jsonl
memory/luna_fast_recall.sqlite
memory/luna_memory_index_build_report.json

# Phase 5E: regenerable playbook engine artifacts. Tracked sources of truth
# are memory/luna_self_healing_playbooks.schema.json (record shape) and
# memory/luna_self_healing_playbooks_seed.json (curated seed set). Match
# reports and runtime jsonl below are rebuildable by the engine.
memory/luna_self_healing_playbooks.jsonl
memory/luna_playbook_match_report.json

# Phase 5F: regenerable upgrade-gate decision reports. Tracked sources of
# truth are memory/luna_upgrade_gate_policy.schema.json and
# memory/luna_upgrade_gate_policy.json. The decision artifacts below are
# rebuilt on demand by luna_upgrade_gate.write_gate_report().
memory/luna_upgrade_gate_report.json
memory/luna_upgrade_gate_report.md

# Phase 5G: regenerable capability scorecard outputs. Tracked sources of
# truth are memory/luna_capability_scorecard.schema.json and
# memory/luna_capability_scorecard_config.json. The runtime artifacts below
# are rebuilt on demand by luna_capability_scorecard.build_capability_scorecard().
memory/luna_capability_scorecard.json
memory/luna_capability_scorecard.md
memory/luna_capability_scorecard_build_report.json
